#!/usr/bin/env sh
# Focus OpenWhispr if it is already running; otherwise launch it.
# Linux-only helper for the OpenWhispr .deb install.

set -eu

if [ "$(uname -s)" != "Linux" ]; then
  echo "open-whispr: Linux-only helper" >&2
  exit 1
fi

launcher="/opt/OpenWhispr/open-whispr"
if [ ! -x "$launcher" ]; then
  echo "open-whispr: launcher not found at $launcher" >&2
  echo "Install the OpenWhispr .deb from https://github.com/OpenWhispr/openwhispr/releases/latest" >&2
  exit 127
fi

is_running() {
  pgrep -f '^/opt/OpenWhispr/open-whispr( |$)|^/opt/OpenWhispr/open-whispr-app( |$)' >/dev/null 2>&1
}

focus_openwhispr() {
  if [ -n "${SWAYSOCK:-}" ] && command -v swaymsg >/dev/null 2>&1; then
    swaymsg '[class="open-whispr"] focus' >/dev/null 2>&1 && return 0
  fi

  if [ -n "${I3SOCK:-}" ] && command -v i3-msg >/dev/null 2>&1; then
    i3-msg '[class="open-whispr"] focus' >/dev/null 2>&1 && return 0
  fi

  return 1
}

if is_running; then
  focus_openwhispr || true
  exit 0
fi

log_dir="${XDG_CACHE_HOME:-$HOME/.cache}/openwhispr"
mkdir -p "$log_dir"
nohup "$launcher" "$@" >"$log_dir/launcher.log" 2>&1 &

# Give Electron a moment to create the window, then focus it on i3/sway.
sleep 1
focus_openwhispr || true
