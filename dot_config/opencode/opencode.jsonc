{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": false,
    },
  },
  "provider": {
    "google-vertex": {
      "models": {
        "claude-opus-4-8@default": {
          "options": {
            "thinking": { "type": "adaptive", "display": "summarized" },
            "effort": "high",
          },
          "variants": {
            "high": {
              "thinking": { "type": "adaptive", "display": "summarized" },
              "effort": "high",
            },
            "max": {
              "thinking": { "type": "adaptive", "display": "summarized" },
              "effort": "max",
            },
          },
        },
      },
    },
    "google-vertex-anthropic": {
      "models": {
        "claude-opus-4-8@default": {
          "options": {
            "thinking": { "type": "adaptive", "display": "summarized" },
            "effort": "high",
          },
          "variants": {
            "high": {
              "thinking": { "type": "adaptive", "display": "summarized" },
              "effort": "high",
            },
            "max": {
              "thinking": { "type": "adaptive", "display": "summarized" },
              "effort": "max",
            },
          },
        },
      },
    },
  },
  "agent": {
    "explore": {
      "model": "opencode-go/deepseek-v4-flash",
    },
  },
}
