[user]
	name = Jerry Genser
	email = 8715980+jkgenser@users.noreply.github.com
[init]
	defaultBranch = main
[core]
	editor = nvim -f
[pull]
	rebase = true
[merge]
	tool = nvimdiff
	conflictstyle = diff3
[mergetool]
	keepBackup = false
	prompt = true
[credential "https://github.com"]
	helper = 
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !gh auth git-credential
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
